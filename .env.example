# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
POSTGRES_PASSWORD=change_me_db_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ── Nextcloud admin ───────────────────────────────────────────────────────────
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change_me_admin_password

# Публичный IP или домен Nextcloud (для trusted_domains)
NEXTCLOUD_PUBLIC_HOST=192.168.88.10

# ── Euro-Office JWT ───────────────────────────────────────────────────────────
# Сгенерировать: openssl rand -hex 32
JWT_SECRET=change_me_jwt_secret_min_32_chars

# ── Порты на хосте docker-compose ─────────────────────────────────────────────
PROXY_HTTP_PORT=80
EURO_OFFICE_PORT=8080

# ── Публичные URL ─────────────────────────────────────────────────────────────
# HTTP (без TLS):
NEXTCLOUD_PUBLIC_URL=http://192.168.88.10
EURO_OFFICE_PUBLIC_URL=http://192.168.88.10:8080

# HTTPS + LAN-домены (раскомментировать после настройки TLS + mkcert):
#NEXTCLOUD_PUBLIC_URL=https://nextcloud.lan
#EURO_OFFICE_PUBLIC_URL=https://eurooffice.lan

# ── LAN IP для extra_hosts Euro-Office контейнера ─────────────────────────────
# IP, на который резолвятся nextcloud.lan и eurooffice.lan внутри Docker-сети.
# Обычно это IP reverse proxy.
NEXTCLOUD_HOST_IP=192.168.88.10
EURO_OFFICE_HOST_IP=192.168.88.10
